  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "latest",
    "eslint": "^9.0.0"
  }
}
