{
  "name": "furnitrack",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": { "pnpm": ">=9.0.0", "node": ">=20.0.0" },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
